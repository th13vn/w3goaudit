__pycache__/

# scripts/ holds dev-only tooling (benchmark harness, template forge, helpers)
# and is not published. Benchmark-dependent Go tests skip when it is absent.
/scripts/

# Benchmark runs are generated host artifacts. Keep only the directory marker;
# default and named runs must never be tracked.
benchmarks/results/*
!benchmarks/results/.gitkeep
