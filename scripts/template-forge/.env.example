# ----------------------------------------------------------------------------
# template-forge configuration. Copy to `.env` and fill in. `.env` is gitignored.
# ----------------------------------------------------------------------------

# Solodit API key (sk_...). Get one at https://solodit.cyfrin.io -> profile -> API Keys.
CYFRIN_API_KEY=

# Etherscan API key — incident enrichment (verified source + attack tx).
ETHERSCAN_API_KEY=

# GitHub token — raises rate limits for DeFiHackLabs listing + finding-source pulls.
GITHUB_TOKEN=

# Optional. Only used by `fetch:incidents --execute` to reproduce a Foundry PoC
# against a forked archive node. Leave blank to skip PoC execution.
FORK_RPC_URL=

# opencode model id, in opencode's "provider/model" format (e.g. anthropic/claude-opus-4-8).
OPENCODE_MODEL=

# Path to the opencode binary.
OPENCODE_BIN=opencode

# Optional. Attach all opencode runs to a persistent headless server to amortize
# startup cost (e.g. http://localhost:4096). Leave blank to spawn per call.
OPENCODE_ATTACH=

# Path to the w3goaudit binary (relative to scripts/template-forge/).
W3GOAUDIT_BIN=../../w3goaudit

# Path to the w3goaudit corpus used by the REGRESSION gate (relative to scripts/template-forge/).
W3GOAUDIT_CORPUS=../../test-data

# Solodit transport: mcp | rest  (confirm against live docs at build time).
SOLODIT_TRANSPORT=mcp

# Base URL for the Solodit REST API (only used when SOLODIT_TRANSPORT=rest).
# Confirm the exact base + endpoint paths against the live docs before relying on it.
SOLODIT_API_BASE=

# Requests-per-second ceiling for Solodit politeness.
RATE_LIMIT_RPS=1

# Max repair attempts per candidate before it is shelved.
REPAIR_MAX_RETRIES=3

# Consecutive clean variant rounds required before a candidate is promote-eligible.
IMPROVE_STABLE_ROUNDS=2

# Path to the finding-root-cause skill the AI `explore` stage loads (default
# resolves the repo's _ai-globals copy; an embedded fallback is used if absent).
ROOTCAUSE_SKILL_PATH=../../../_ai-globals/skills/finding-root-cause/SKILL.md

# Findings whose root-cause text is shorter than this get AI root-cause
# exploration; richer findings skip it to save tokens. Incidents always explore.
EXPLORE_MIN_ROOTCAUSE_CHARS=400
