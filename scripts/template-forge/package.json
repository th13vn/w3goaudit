{
  "name": "template-forge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Dev-time pipeline: DeFiHackLabs incidents + Solodit findings -> machine-gated WQL templates for w3goaudit.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "fetch:incidents": "tsx src/cli/fetch-incidents.ts",
    "fetch:findings": "tsx src/cli/fetch-findings.ts",
    "forge": "tsx src/cli/forge.ts",
    "improve": "tsx src/cli/improve.ts",
    "promote": "tsx src/cli/promote.ts",
    "status": "tsx src/cli/status.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
