{
  "_comment": "Detector manifest for Slither. Slither's detectors are built-in Python (no external rule files), so this manifest is the canonical list the benchmark uses to (a) map Slither's native check IDs onto shared benchmark categories and (b) scope the corpus to what Slither can actually find. `id` is the exact `check` value Slither emits in --json output; `category` is the shared benchmark category key. run_benchmark.py auto-loads these as aliases so any check Slither reports that we list here is credited, never silently dropped.",
  "tool": "slither",
  "source": "https://github.com/crytic/slither",
  "detectors_doc": "https://github.com/crytic/slither/wiki/Detector-Documentation",
  "ref": "0.10.x",
  "detectors": [
    { "id": "reentrancy-eth",            "title": "Reentrancy (ETH)",                       "severity": "High",          "category": "reentrancy" },
    { "id": "reentrancy-no-eth",         "title": "Reentrancy (no ETH)",                    "severity": "Medium",        "category": "reentrancy" },
    { "id": "reentrancy-unlimited-gas",  "title": "Reentrancy (unlimited gas, transfer/send)", "severity": "Informational", "category": "reentrancy" },
    { "id": "reentrancy-benign",         "title": "Reentrancy (benign / stale balance)",    "severity": "Low",           "category": "reentrancy-balance" },
    { "id": "reentrancy-events",         "title": "Reentrancy (events after external call)","severity": "Low",           "category": "reentrancy-balance" },
    { "id": "arbitrary-send-eth",        "title": "Functions that send ETH to arbitrary destinations", "severity": "High", "category": "arbitrary-send-eth" },
    { "id": "arbitrary-send-erc20",      "title": "transferFrom with arbitrary from",       "severity": "High",          "category": "arbitrary-transferfrom" },
    { "id": "arbitrary-send-erc20-permit","title": "transferFrom with arbitrary from (permit)","severity": "High",        "category": "arbitrary-transferfrom" },
    { "id": "controlled-delegatecall",   "title": "Controlled delegatecall destination",    "severity": "High",          "category": "controlled-delegatecall" },
    { "id": "delegatecall-loop",         "title": "Payable delegatecall in a loop",         "severity": "High",          "category": "delegatecall-loop" },
    { "id": "calls-loop",                "title": "Calls inside a loop",                    "severity": "Low",           "category": "delegatecall-loop" },
    { "id": "msg-value-loop",            "title": "msg.value inside a loop",                "severity": "High",          "category": "msg-value-loop" },
    { "id": "suicidal",                  "title": "Functions allowing anyone to destruct the contract", "severity": "High", "category": "selfdestruct" },
    { "id": "tx-origin",                 "title": "Dangerous usage of tx.origin",           "severity": "Medium",        "category": "tx-origin" },
    { "id": "incorrect-equality",        "title": "Dangerous strict equalities",            "severity": "Medium",        "category": "dangerous-strict-equality" },
    { "id": "divide-before-multiply",    "title": "Imprecise arithmetic: divide before multiply", "severity": "Medium",  "category": "divide-before-multiply" },
    { "id": "incorrect-exp",             "title": "Incorrect exponentiation (^ vs **)",     "severity": "High",          "category": "incorrect-exp" },
    { "id": "weak-prng",                 "title": "Weak PRNG (block.timestamp/blockhash/now)","severity": "High",        "category": "weak-prng" },
    { "id": "unchecked-transfer",        "title": "Unchecked ERC20 transfer return value",  "severity": "Medium",        "category": "unchecked-erc20-transfer" },
    { "id": "unchecked-lowlevel",        "title": "Unchecked low-level call return value",  "severity": "Medium",        "category": "unchecked-lowlevel-call" },
    { "id": "unchecked-send",            "title": "Unchecked send return value",            "severity": "Medium",        "category": "unchecked-send" },
    { "id": "unprotected-upgrade",       "title": "Unprotected upgradeable contract (initializer)", "severity": "High",  "category": "unprotected-initializer" },
    { "id": "constant-function-state",   "title": "Constant/view/pure functions changing state", "severity": "Medium",  "category": "view-pure-state-write" },
    { "id": "boolean-cst",               "title": "Misuse of a boolean constant",           "severity": "Medium",        "category": "boolean-cst" },
    { "id": "boolean-equal",             "title": "Comparison to boolean constant",         "severity": "Informational", "category": "boolean-cst" },
    { "id": "timestamp",                 "title": "Dangerous use of block.timestamp",       "severity": "Low",           "category": "block-timestamp" }
  ]
}
